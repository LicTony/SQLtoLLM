<Window x:Class="SQLtoLLM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SQLtoLLM.UI"
        Title="MSSQL Context Extractor for LLM"
        Height="780" Width="980"
        MinHeight="680" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgBase"       Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgSurface"    Color="#27273D"/>
        <SolidColorBrush x:Key="BgInput"      Color="#1A1A2E"/>
        <SolidColorBrush x:Key="Accent"        Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHover"   Color="#1E8FE8"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8888AA"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#3A3A5C"/>
        <SolidColorBrush x:Key="SuccessColor"  Color="#4CAF7D"/>
        <SolidColorBrush x:Key="WarningColor"  Color="#FFB347"/>
        <SolidColorBrush x:Key="ErrorColor"    Color="#F44747"/>

        <!-- Section card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgSurface}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="18"/>
            <Setter Property="Margin"           Value="0,0,0,14"/>
        </Style>

        <!-- Section title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Foreground"       Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>

        </Style>

        <!-- Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,0,3"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"           Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"          Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,6"/>
            <Setter Property="FontFamily"           Value="Segoe UI"/>
            <Setter Property="FontSize"             Value="13"/>
            <Setter Property="CaretBrush"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="SelectionBrush"       Value="{StaticResource Accent}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <!-- RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,0,20,0"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="18,8"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3A3A5C"/>
                                <Setter Property="Foreground" Value="#666688"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005FA3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D2A40"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"    Value="#666688"/>
                                <Setter Property="BorderBrush"   Value="#3A3A5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"              Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"              Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground"           Value="#22223A"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E34"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2D2D4A"/>
            <Setter Property="HeadersVisibility"       Value="Column"/>
            <Setter Property="SelectionUnit"           Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"     Value="False"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="CanUserDeleteRows"       Value="False"/>
            <Setter Property="FontSize"                Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#1A1A2E"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="10,6"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0D2A40"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"        Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable"      Value="False"/>
        </Style>

        <!-- ComboBox for editable type -->
        <Style x:Key="GridCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1A1A2E"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ HEADER ═══════════════════════ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="MSSQL Context Extractor"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Extract SQL Server schema context for LLM-assisted development"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══════════════════════ MAIN SCROLL ═══════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ──────────── SECTION 1: CONNECTION ──────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="① CONNECTION" Style="{StaticResource SectionTitle}"/>

                        <!-- Radio buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <RadioButton x:Name="RadioConnString"
                                         Content="Connection String"
                                         GroupName="ConnMode"
                                         IsChecked="True"
                                         Checked="RadioConnMode_Changed"/>
                            <RadioButton x:Name="RadioCredentials"
                                         Content="Server / Database / Credentials"
                                         GroupName="ConnMode"
                                         Checked="RadioConnMode_Changed"/>
                        </StackPanel>

                        <!-- Panel A: Connection String -->
                        <StackPanel x:Name="PanelConnString">
                            <TextBlock Text="Connection String" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtConnString"
                                     Height="36"
                                     VerticalContentAlignment="Center" Text="Server=DESKTOP-TONY\\SQLEXPRESS;Database=MiBaseDeDatos;Integrated Security=True;TrustServerCertificate=True;"/>
                        </StackPanel>

                        <!-- Panel B: Credentials -->
                        <StackPanel x:Name="PanelCredentials" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="0" x:Name="TxtServer" Height="36" VerticalContentAlignment="Center"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Port" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="2" x:Name="TxtPort" Height="36" VerticalContentAlignment="Center" Text="1433"/>

                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Database" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="4" x:Name="TxtDatabase" Height="36" VerticalContentAlignment="Center"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="User" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="4" Grid.Column="0" x:Name="TxtUser" Height="36" VerticalContentAlignment="Center"/>

                                <TextBlock Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="3" Text="Password" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3" x:Name="TxtPassword" Height="36" VerticalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Connect button + status -->
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0" VerticalAlignment="Center">
                            <Button x:Name="BtnConnect"
                                    Content="Connect"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnConnect_Click"/>
                            <TextBlock x:Name="TxtConnStatus"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ──────────── SECTION 2: OBJECTS ──────────── -->
                <Border x:Name="CardObjects" Style="{StaticResource Card}" IsEnabled="False" Opacity="0.5">
                    <StackPanel>
                        <TextBlock Text="② OBJECTS TO EXTRACT" Style="{StaticResource SectionTitle}"/>

                        <TextBlock Style="{StaticResource FieldLabel}"
                                   Text="Paste a comma-separated list of objects (e.g. dbo.Clientes, dbo.SP_Saldo, dbo.VW_Saldos)"/>
                        <TextBox x:Name="TxtObjects"
                                 Height="60"
                                 Margin="0,3,0,10"
                                 VerticalContentAlignment="Top"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>

                        <Button x:Name="BtnResolve"
                                Content="Resolve Objects"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                Click="BtnResolve_Click"/>

                        <!-- Resolution grid -->
                        <DataGrid x:Name="GridObjects"
                                  Margin="0,12,0,0"
                                  MinHeight="80"
                                  MaxHeight="220"
                                  Visibility="Collapsed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Object Name"
                                                    Binding="{Binding ObjectName}"
                                                    Width="*"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Detected Type"
                                                    Binding="{Binding DetectedType}"
                                                    Width="130"
                                                    IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Editable Type" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{x:Static ui:ObjectRow.AvailableTypes}"
                                                      SelectedItem="{Binding EditableType, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource GridCombo}"
                                                      SelectionChanged="GridCombo_Changed"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="140"
                                                    IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ──────────── SECTION 3: EXECUTE ──────────── -->
                <Border x:Name="CardExecute" Style="{StaticResource Card}" IsEnabled="False" Opacity="0.5">
                    <StackPanel>
                        <TextBlock Text="③ EXTRACT &amp; COPY" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button x:Name="BtnExecute"
                                    Content="▶  Execute Extraction"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnExecute_Click"/>
                            <Button x:Name="BtnCopy"
                                    Content="⧉  Copy to Clipboard"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    Click="BtnCopy_Click"/>
                            <TextBlock x:Name="TxtExecStatus"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>

                        <TextBox x:Name="TxtResult"
                                 Height="220"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
